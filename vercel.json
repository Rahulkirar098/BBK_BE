{
  "version": 2,
  "framework": null,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.ts"
    }
  ],
  "functions": {
    "index.ts": {
      "maxDuration": 30
    }
  }
}